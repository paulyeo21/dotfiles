command! WQ wq
command! Wq wq
command! W w
command! Q q

nnoremap 0 ^
nnoremap ^ 0
nnoremap k gk
nnoremap j gj

nnoremap <leader>so :source $MYVIMRC<cr>:doautocmd FileType<cr>
nnoremap <leader>p :set paste<cr>o<esc>"*]p:set nopaste<cr>
nnoremap <leader>e :e <C-R>=escape(expand("%:p:h"),' ') . '/'<CR>
nnoremap <leader>t :tabe <C-R>=escape(expand("%:p:h"), ' ') . '/'<CR>
nnoremap <leader>cp mmggVG"*y`m
nnoremap <leader>mv :call RenameFile()<cr>

" Daily note — mirrors the 'note' shell alias
let s:vault = $HOME . '/Library/Mobile Documents/iCloud~md~obsidian/Documents'
command! Note execute 'edit ' . fnameescape(s:vault . '/daily/' . strftime('%Y-%m-%d') . '.md')

" Quickfix navigation (]q / [q follows vim-unimpaired convention)
nnoremap ]q :cnext<cr>
nnoremap [q :cprev<cr>
nnoremap <leader>cc :cclose<cr>

" vim:ft=vim
