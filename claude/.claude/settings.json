{
  "model": "opus[1m]",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p /tmp/claude_attention; tmux set-option -w @claude_attention 1 2>/dev/null; touch /tmp/claude_attention/$(tmux display-message -p '#{session_name}:#{window_index}') 2>/dev/null"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -u @claude_attention 2>/dev/null; rm -f /tmp/claude_attention/$(tmux display-message -p '#{session_name}:#{window_index}') 2>/dev/null"
          }
        ]
      }
    ]
  }
}
